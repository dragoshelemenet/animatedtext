{
  "name": "motion-text-reels-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 0.0.0.0\" \"node server/index.js\"",
    "dev:app": "vite --host 0.0.0.0",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "render": "remotion render src/remotion/index.jsx MotionText exports/motion-text.mp4 --props=props.json --codec=h264 --overwrite"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "express": "^4.19.2",
    "concurrently": "^9.0.1",
    "remotion": "^4.0.300",
    "@remotion/cli": "^4.0.300"
  }
}
